# ============================================================================
# NOVA-7 Launch Demo — Environment Configuration
# ============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Required variables are marked with [REQUIRED].
# Optional variables have sensible defaults or enable optional features.
# ============================================================================

# ── Elastic / Elasticsearch ──────────────────────────────────────────────────
# [REQUIRED] Your Elastic Cloud or self-hosted Elasticsearch endpoint.
# This is where the OpenTelemetry Collector sends all telemetry data.
# Example: https://my-deployment-abcdef.es.us-central1.gcp.cloud.es.io:443
ELASTIC_ENDPOINT=

# [REQUIRED] Elasticsearch API key for the OTel Collector.
# Create one in Kibana: Stack Management > API Keys.
# The key needs permissions to write to logs-*, metrics-*, and traces-* indices.
ELASTIC_API_KEY=

# Elasticsearch URL for direct API access from the NOVA-7 app.
# Used for health checks and configuration validation.
# Usually the same as ELASTIC_ENDPOINT but may differ in some setups.
ELASTIC_URL=

# ── OpenTelemetry (OTLP) ────────────────────────────────────────────────────
# OTLP HTTP endpoint for the OpenTelemetry Collector.
# Default value works when running in Docker alongside the collector.
# Only change this if you are running outside Docker or using a remote collector.
OTLP_ENDPOINT=http://otel-collector:4318

# API key for authenticating with the OTLP endpoint.
# Required when sending directly to Elastic Cloud APM Server.
# Leave empty when using a local OTel Collector (the collector handles auth).
OTLP_API_KEY=

# Authentication type for the OTLP endpoint.
# "ApiKey" — Elastic API key authentication (default)
# "Bearer" — Bearer token authentication
OTLP_AUTH_TYPE=ApiKey

# ── Twilio (SMS + Voice Alerts) ──────────────────────────────────────────────
# Optional — enables SMS and voice call notifications during the demo.
# Sign up at https://www.twilio.com/ to get these credentials.

# Twilio Account SID — found on your Twilio Console dashboard.
# Example: ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_ACCOUNT_SID=

# Twilio Auth Token — found on your Twilio Console dashboard.
# Keep this secret! Never commit it to version control.
TWILIO_AUTH_TOKEN=

# Twilio phone number to send FROM (must be a Twilio number you own).
# Format: +1XXXXXXXXXX (E.164 format)
TWILIO_FROM_NUMBER=

# Phone number to send alerts TO (the demo presenter's phone).
# Format: +1XXXXXXXXXX (E.164 format)
TWILIO_TO_NUMBER=

# ── Slack (Webhook Alerts) ───────────────────────────────────────────────────
# Optional — enables Slack channel notifications during the demo.
# Create an Incoming Webhook at: https://api.slack.com/messaging/webhooks

# Slack Incoming Webhook URL for posting alert messages.
# Example: https://hooks.slack.com/services/T00000000/B00000000/XXXXXXXXXXXXXXXXXXXXXXXX
SLACK_WEBHOOK_URL=

# ── Application Settings ────────────────────────────────────────────────────
# Port the NOVA-7 application listens on (inside the container).
# The docker-compose.yml maps this to the same port on the host.
APP_PORT=8080

# Host address the application binds to.
# 0.0.0.0 allows connections from outside the container (required for Docker).
APP_HOST=0.0.0.0
