# ============================================================================
# Elastic Observability Demo Platform — Environment Configuration
# ============================================================================
# This file is auto-populated when you deploy a scenario via the web UI.
# You do NOT need to edit this manually — enter credentials in the scenario
# selector at http://<your-host>/ and they are persisted here automatically.
#
# If you prefer to pre-configure, copy this file to .env and fill in values:
#   cp .env.example .env
# ============================================================================

# ── Elastic / Elasticsearch ──────────────────────────────────────────────────
# Your Elastic Cloud Elasticsearch endpoint.
# Example: https://my-deployment.es.us-central1.gcp.cloud.es.io:443
ELASTIC_URL=

# Elasticsearch/Kibana API key (base64-encoded).
# Create in Kibana: Stack Management > API Keys (needs broad permissions).
ELASTIC_API_KEY=

# Kibana endpoint URL.
# Example: https://my-deployment.kb.us-central1.gcp.cloud.es.io:443
KIBANA_URL=

# ── OpenTelemetry (OTLP) ────────────────────────────────────────────────────
# OTLP HTTP endpoint for sending telemetry directly to Elastic Cloud.
# This is the APM/OTLP endpoint from your Cloud console.
# Example: https://my-deployment.apm.us-central1.gcp.cloud.es.io:443
OTLP_ENDPOINT=

# API key for the OTLP endpoint (usually the same as ELASTIC_API_KEY).
OTLP_API_KEY=

# Authentication type: "ApiKey" (default) or "Bearer"
OTLP_AUTH_TYPE=ApiKey

# ── Twilio (SMS + Voice Alerts) — Optional ───────────────────────────────────
# Enables SMS and voice call notifications during demos.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_TO_NUMBER=

# ── Slack (Webhook Alerts) — Optional ────────────────────────────────────────
# Enables Slack channel notifications during demos.
SLACK_WEBHOOK_URL=
