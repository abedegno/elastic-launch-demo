{
  "tool_id": "launch_safety_assessment",
  "name": "Launch Safety Assessment",
  "description": "Perform a comprehensive safety assessment for the NOVA-7 launch. Evaluates all critical subsystems against launch commit criteria, checks for active Flight Termination System (FTS) anomalies, verifies range safety radar tracking, and produces a GO/NO-GO recommendation. Use this tool when multiple anomalies are detected or before recommending a launch phase transition.",
  "type": "elasticsearch",
  "parameters": {
    "type": "object",
    "required": [],
    "properties": {
      "assessment_type": {
        "type": "string",
        "enum": ["full", "subsystem", "fts_only", "range_safety"],
        "default": "full",
        "description": "Type of safety assessment. 'full' checks all subsystems, 'subsystem' checks a specific one, 'fts_only' checks Flight Termination System, 'range_safety' checks range tracking."
      },
      "subsystem": {
        "type": "string",
        "enum": ["propulsion", "guidance", "communications", "payload", "relay", "ground", "validation", "safety"],
        "description": "Specific subsystem to assess (required when assessment_type is 'subsystem')."
      },
      "time_range": {
        "type": "string",
        "default": "now-10m",
        "description": "Time window for the assessment. Default last 10 minutes."
      },
      "strict_mode": {
        "type": "boolean",
        "default": true,
        "description": "In strict mode, any active ERROR in a safety-critical subsystem results in NO-GO. Default true."
      }
    }
  },
  "indices": ["logs", "metrics-generic-default"],
  "execution": {
    "type": "multi_search",
    "queries": [
      {
        "description": "Count active errors by service",
        "index": "logs",
        "template": {
          "size": 0,
          "query": {
            "bool": {
              "must": [
                { "term": { "severity_text": "ERROR" } }
              ],
              "filter": [
                { "range": { "@timestamp": { "gte": "{{time_range}}" } } }
              ]
            }
          },
          "aggs": {
            "by_service": {
              "terms": { "field": "service.name", "size": 10 },
              "aggs": {
                "latest_errors": {
                  "top_hits": {
                    "size": 3,
                    "sort": [{ "@timestamp": "desc" }],
                    "_source": ["body.text", "@timestamp"]
                  }
                }
              }
            }
          }
        }
      },
      {
        "description": "Check for FTS anomalies specifically",
        "index": "logs",
        "template": {
          "size": 10,
          "query": {
            "bool": {
              "must": [
                { "match_phrase": { "body.text": "FTSCheckException" } },
                { "term": { "severity_text": "ERROR" } }
              ],
              "filter": [
                { "range": { "@timestamp": { "gte": "{{time_range}}" } } }
              ]
            }
          },
          "sort": [{ "@timestamp": "desc" }]
        }
      },
      {
        "description": "Check for range safety tracking losses",
        "index": "logs",
        "template": {
          "size": 10,
          "query": {
            "bool": {
              "must": [
                { "match_phrase": { "body.text": "TrackingLossException" } },
                { "term": { "severity_text": "ERROR" } }
              ],
              "filter": [
                { "range": { "@timestamp": { "gte": "{{time_range}}" } } }
              ]
            }
          },
          "sort": [{ "@timestamp": "desc" }]
        }
      },
      {
        "description": "Check active cascade warnings across services",
        "index": "logs",
        "template": {
          "size": 0,
          "query": {
            "bool": {
              "must": [
                { "term": { "severity_text": "WARN" } }
              ],
              "filter": [
                { "range": { "@timestamp": { "gte": "{{time_range}}" } } }
              ]
            }
          },
          "aggs": {
            "cascade_services": {
              "terms": { "field": "service.name", "size": 20 }
            }
          }
        }
      }
    ],
    "post_processing": {
      "go_nogo_rules": [
        { "condition": "fts_errors > 0", "result": "NO-GO", "reason": "Active Flight Termination System anomaly" },
        { "condition": "tracking_losses > 0", "result": "NO-GO", "reason": "Range safety tracking loss detected" },
        { "condition": "propulsion_errors > 0 AND strict_mode", "result": "NO-GO", "reason": "Active propulsion subsystem fault" },
        { "condition": "guidance_errors > 0 AND strict_mode", "result": "NO-GO", "reason": "Active guidance subsystem fault" },
        { "condition": "cascade_count > 3", "result": "HOLD", "reason": "Multiple cascading failures detected" }
      ]
    }
  },
  "metadata": {
    "mission_id": "NOVA-7",
    "category": "safety",
    "priority": "critical"
  }
}
