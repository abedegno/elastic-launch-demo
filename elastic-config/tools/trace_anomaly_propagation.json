{
  "tool_id": "trace_anomaly_propagation",
  "name": "Trace Anomaly Propagation",
  "description": "Trace the propagation path of an anomaly across NOVA-7 services and cloud boundaries. Given a source channel or error type, this tool identifies the cascade chain: which services were directly affected, which experienced secondary cascade effects, and the temporal order of fault propagation. Essential for understanding cross-cloud failure modes in the multi-cloud architecture (AWS <-> GCP <-> Azure).",
  "type": "elasticsearch",
  "parameters": {
    "type": "object",
    "required": ["error_type"],
    "properties": {
      "error_type": {
        "type": "string",
        "description": "The error type to trace propagation for (e.g., FuelPressureException, GPSMultipathException)."
      },
      "time_range": {
        "type": "string",
        "default": "now-15m",
        "description": "Time window to analyze for propagation. Default last 15 minutes."
      },
      "include_cascade": {
        "type": "boolean",
        "default": true,
        "description": "Include cascade (secondary) effects in the trace."
      }
    }
  },
  "indices": ["logs"],
  "execution": {
    "type": "multi_search",
    "queries": [
      {
        "description": "Find direct fault events for this error type",
        "index": "logs",
        "template": {
          "size": 50,
          "query": {
            "bool": {
              "must": [
                { "match_phrase": { "body.text": "{{error_type}}" } },
                { "term": { "severity_text": "ERROR" } }
              ],
              "filter": [
                { "range": { "@timestamp": { "gte": "{{time_range}}" } } }
              ]
            }
          },
          "sort": [{ "@timestamp": "asc" }]
        }
      },
      {
        "description": "Find cascade WARN events across services",
        "index": "logs",
        "template": {
          "size": 50,
          "query": {
            "bool": {
              "must": [
                { "term": { "severity_text": "WARN" } }
              ],
              "filter": [
                { "range": { "@timestamp": { "gte": "{{time_range}}" } } }
              ]
            }
          },
          "sort": [{ "@timestamp": "asc" }]
        }
      },
      {
        "description": "Aggregate propagation timeline by service",
        "index": "logs",
        "template": {
          "size": 0,
          "query": {
            "bool": {
              "must": [
                { "terms": { "severity_text": ["ERROR", "WARN"] } }
              ],
              "filter": [
                { "range": { "@timestamp": { "gte": "{{time_range}}" } } }
              ]
            }
          },
          "aggs": {
            "propagation_timeline": {
              "date_histogram": {
                "field": "@timestamp",
                "fixed_interval": "10s"
              },
              "aggs": {
                "by_service": {
                  "terms": { "field": "service.name" }
                }
              }
            }
          }
        }
      }
    ]
  },
  "metadata": {
    "mission_id": "NOVA-7",
    "category": "investigation",
    "priority": "primary"
  }
}
