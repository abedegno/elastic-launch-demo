{
  "tool_id": "search_subsystem_health",
  "name": "Search Subsystem Health",
  "description": "Query the health status of NOVA-7 vehicle subsystems by aggregating recent telemetry. Returns error counts, warning counts, and overall health status for each subsystem (propulsion, guidance, communications, payload, relay, ground, validation, safety). Use this tool to get a high-level view of which subsystems are degraded.",
  "type": "elasticsearch",
  "parameters": {
    "type": "object",
    "required": [],
    "properties": {
      "service_name": {
        "type": "string",
        "enum": ["mission-control", "fuel-system", "ground-systems", "navigation", "comms-array", "payload-monitor", "sensor-validator", "telemetry-relay", "range-safety"],
        "description": "Specific service to query. If omitted, returns health for all services."
      },
      "time_range": {
        "type": "string",
        "default": "now-15m",
        "description": "Time window for health assessment. Default last 15 minutes."
      },
      "include_warnings": {
        "type": "boolean",
        "default": true,
        "description": "Include WARNING-level events in the health assessment."
      }
    }
  },
  "index": "logs",
  "execution": {
    "type": "elasticsearch_query",
    "template": {
      "size": 0,
      "query": {
        "bool": {
          "filter": [
            { "range": { "@timestamp": { "gte": "{{time_range}}" } } },
            { "terms": { "severity_text": ["ERROR", "WARN"] } }
          ]
        }
      },
      "aggs": {
        "by_service": {
          "terms": { "field": "service.name", "size": 10 },
          "aggs": {
            "by_severity": {
              "terms": { "field": "severity_text" }
            },
            "latest_event": {
              "top_hits": {
                "size": 1,
                "sort": [{ "@timestamp": "desc" }],
                "_source": ["body.text", "@timestamp", "severity_text"]
              }
            }
          }
        }
      }
    }
  },
  "metadata": {
    "mission_id": "NOVA-7",
    "category": "health-monitoring",
    "priority": "primary"
  }
}
